@inject MidStateShuttleService.Service.IListService ListServices
@model MidStateShuttleService.Models.Routes

<link rel="stylesheet" href="/css/CheckIn.css" />

<body>
    <div class="wrapper wrapper--w680">
        <form asp-action="Create" asp-controller="ShuttleRoutes" method="post" class="form form-1">
            <div class="form-body">
                <h2 class="title">Create Route</h2>

                <div class="input-fields">
                    <label>Pick Up Location</label>
                    <select asp-for="PickUpLocationID" name="PickUpLocationID"
                            asp-items="ListServices.GetLocationList().Select(x => new SelectListItem{ Text = x.Name, Value = x.LocationID.ToString()})" class="form-control input--style-1" required></select>
                            
                    <div class="div-line"></div>
                </div>

                <div class="input-fields">
                    <label>Drop Off Location</label>
                    <select asp-for="DropOffLocationID" name="DropOffLocationID"
                            asp-items="ListServices.GetLocationList().Select(x => new SelectListItem{ Text = x.Name, Value = x.LocationID.ToString()})" class="form-control input--style-1" required></select>
                    <div class="div-line"></div>
                </div>

                <div class="input-fields">
                    <label>Pick Up Time</label>
                    <input asp-for="PickUpTime" name="PickUpTime" type="time" class="form-control input--style-1" required />
                    <div class="div-line"></div>
                </div>

                <div class="input-fields">
                    <label>Drop Off Time</label>
                    <input asp-for="DropOffTime" name="PickUpTime" type="time" class="form-control input--style-1" required />
                    <div class="div-line"></div>
                </div>

                <div class="input-fields">
                    <label>Additional Details</label>
                    <textarea asp-for="AdditionalDetails" name="AdditionalDetails" class="form-control input--style-1" placeholder="Enter additional details"></textarea>
                    <div class="div-line"></div>
                </div>

                <div class="p-t-20">
                    <button type="submit" class="btn btn--radius btn--green">Create Route</button>
                </div>
            </div>
        </form>
    </div>

    <script src="/js/routes.js"></script>
</body>
